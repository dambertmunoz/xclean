# Copy this to .env.local and fill in real values.
# .env.local is gitignored.

# Password for the admin dashboard. Pick something long.
ADMIN_PASSWORD=change-me-now-something-long

# Secret used to sign the admin session cookie (HMAC-SHA256).
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# Price shown on the landing in USD.
PRICE_USD=10

# Public-facing instructions for the QR payment.
# e.g. "Yape · Plin · USDT TRC20 wallet 0x…"
PAYMENT_LABEL=Yape / Plin / Transferencia
